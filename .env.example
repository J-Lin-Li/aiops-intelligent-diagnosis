# 应用配置
APP_NAME=SuperBizAgent
DEBUG=True
HOST=0.0.0.0
PORT=9900

# DashScope 配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.6-flash
DASHSCOPE_EMBEDDING_MODEL=tongyi-embedding-vision-flash
DASHSCOPE_EMBEDDING_DIM=768

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

# RAG 配置
RAG_TOP_K=3
RAG_MODEL=qwen3.6-flash

# 文档分块配置
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# MCP 服务配置
# 支持的 transport 类型：stdio、sse（腾讯云等 /sse/ 端点）、streamable-http（本地 FastMCP）
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:18003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:18004/mcp

# Redis 缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_TTL=3600
REDIS_CACHE_EMPTY_TTL=300

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=superbiz

# 代理绕过（如本地有代理，防止 SSLEOFError）
# NO_PROXY=dashscope.aliyuncs.com

# Prometheus（告警查询工具，没有实例时优雅报错不影响启动）
PROMETHEUS_BASE_URL=http://127.0.0.1:9090
PROMETHEUS_REQUEST_TIMEOUT=10.0
